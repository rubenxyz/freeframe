FROM python:3.11-slim

WORKDIR /workspace

RUN apt-get update && apt-get install -y \
    ffmpeg \
    imagemagick \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install API dependencies
COPY apps/api/requirements.txt /workspace/apps/api/requirements.txt
RUN pip install --no-cache-dir -r /workspace/apps/api/requirements.txt
RUN pip install --no-cache-dir gunicorn

# Copy transcoder package and API
COPY packages/transcoder /workspace/packages/transcoder
COPY apps/api /workspace/apps/api

# Create non-root user
RUN adduser --disabled-password --no-create-home appuser

WORKDIR /workspace

# No HEALTHCHECK here: this image is shared by the API *and* the Celery
# worker/beat/email_worker, which don't serve HTTP — a baked-in `curl :8000/health`
# marks every worker perpetually "unhealthy". The API's healthcheck lives on the
# `api` service in docker-compose.prod.yml instead.

USER appuser

EXPOSE 8000

CMD ["gunicorn", "apps.api.main:app", \
     "-w", "4", \
     "-k", "uvicorn.workers.UvicornWorker", \
     "--bind", "0.0.0.0:8000", \
     "--timeout", "120", \
     "--graceful-timeout", "30"]
